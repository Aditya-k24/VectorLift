# =============================================================================
# VectorLift — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=dev                  # dev | staging | prod
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
DEBUG=false                  # true in dev only; never true in prod
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ---------------------------------------------------------------------------
# Elasticsearch
# ---------------------------------------------------------------------------
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=vectorlift_passages
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_SCHEME=http     # http | https
ELASTICSEARCH_VERIFY_CERTS=false
ELASTICSEARCH_CA_CERT=        # path to CA cert for TLS

# ---------------------------------------------------------------------------
# Qdrant (dense vector store)
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=vectorlift_dense
QDRANT_API_KEY=               # required for Qdrant Cloud
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=false

# ---------------------------------------------------------------------------
# PostgreSQL (experiment tracking, metadata)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vectorlift
POSTGRES_USER=vectorlift
POSTGRES_PASSWORD=vectorlift_secret
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
# Constructed automatically by settings.py — override if needed:
# DATABASE_URL=postgresql+asyncpg://vectorlift:vectorlift_secret@localhost:5432/vectorlift

# ---------------------------------------------------------------------------
# Redis (caching, session store)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=3600        # default cache TTL

# ---------------------------------------------------------------------------
# Kafka (async event streaming)
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_QUERIES=vectorlift.queries
KAFKA_TOPIC_FEEDBACK=vectorlift.feedback
KAFKA_CONSUMER_GROUP=vectorlift-consumers
KAFKA_AUTO_OFFSET_RESET=earliest

# ---------------------------------------------------------------------------
# External API Keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=               # optional — used for OpenAI embedding fallback
HF_TOKEN=                     # Hugging Face token for gated models/datasets

# ---------------------------------------------------------------------------
# Bi-encoder (query / passage encoder)
# ---------------------------------------------------------------------------
# Path to a locally fine-tuned model; falls back to BIENCODER_PRETRAINED
BIENCODER_MODEL_PATH=
BIENCODER_PRETRAINED=sentence-transformers/msmarco-distilbert-base-tas-b
EMBEDDING_DIM=768
MAX_SEQ_LENGTH=512
BIENCODER_BATCH_SIZE=64
BIENCODER_DEVICE=cpu          # cpu | cuda | mps

# ---------------------------------------------------------------------------
# Cross-encoder reranker
# ---------------------------------------------------------------------------
# Path to a locally fine-tuned model; falls back to CROSSENCODER_PRETRAINED
CROSSENCODER_MODEL_PATH=
CROSSENCODER_PRETRAINED=cross-encoder/ms-marco-MiniLM-L-6-v2
CROSSENCODER_BATCH_SIZE=32
CROSSENCODER_MAX_LENGTH=512
CROSSENCODER_DEVICE=cpu

# ---------------------------------------------------------------------------
# Dataset
# ---------------------------------------------------------------------------
# dev   — tiny slice (~100 passages), for local dev & CI
# small — medium slice (~10k passages), for quick experiments
# full  — complete MS MARCO or custom corpus
DATASET_MODE=dev
DATASET_HF_NAME=ms_marco
DATASET_HF_CONFIG=v1.1
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
INDEX_DIR=data/indexes

# ---------------------------------------------------------------------------
# Retrieval defaults
# ---------------------------------------------------------------------------
# bm25 | dense | hybrid | rerank
RETRIEVAL_DEFAULT_MODE=hybrid
TOP_K_DEFAULT=10
RERANK_TOP_N_DEFAULT=100

# Hybrid fusion weights (must sum to 1.0)
HYBRID_BM25_WEIGHT=0.3
HYBRID_DENSE_WEIGHT=0.7

# Reciprocal Rank Fusion constant (k=60 is standard)
RRF_K=60

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=vectorlift-api
OTEL_TRACES_EXPORTER=otlp    # otlp | console | none
OTEL_METRICS_EXPORTER=otlp
SENTRY_DSN=                  # optional — Sentry error tracking

# ---------------------------------------------------------------------------
# Prefect (workflow orchestration)
# ---------------------------------------------------------------------------
PREFECT_API_URL=http://localhost:4200/api

# ---------------------------------------------------------------------------
# CORS (API)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
CORS_ALLOW_CREDENTIALS=true
